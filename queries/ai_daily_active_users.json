[
  {
    "$match": {
      "createdAt": {
        "$gte": ISODate("2025-01-01T00:00:00Z")
      },
      "companyId": { "$ne": null },
      "referenceId": { "$ne": null }
    }
  },
  {
    "$project": {
      "companyId": 1,
      "referenceId": 1,
      "isoDay": { "$isoDayOfWeek": "$createdAt" },
      "week_end_sunday": {
        "$dateToString": {
          "format": "%Y-%m-%d",
          "date": {
            "$add": [
              "$createdAt",
              { "$multiply": [{ "$subtract": [7, { "$isoDayOfWeek": "$createdAt" }] }, 86400000] }
            ]
          }
        }
      },
      "day": { "$dateToString": { "format": "%Y-%m-%d", "date": "$createdAt" } }
    }
  },
  {
    "$group": {
      "_id": {
        "companyId": "$companyId",
        "week_end_sunday": "$week_end_sunday",
        "day": "$day"
      },
      "daily_users": { "$addToSet": "$referenceId" }
    }
  },
  {
    "$project": {
      "_id": 1,
      "daily_unique_users": { "$size": "$daily_users" },
      "daily_users": 1
    }
  },
  {
    "$group": {
      "_id": {
        "companyId": "$_id.companyId",
        "week_end_sunday": "$_id.week_end_sunday"
      },
      "dau_count": { "$sum": "$daily_unique_users" },
      "daily_user_sets": { "$push": "$daily_users" }
    }
  },
  {
    "$project": {
      "_id": 0,
      "companyId": "$_id.companyId",
      "week_end_sunday": "$_id.week_end_sunday",
      "dau_count": 1,
      "unique_users_count": {
        "$size": {
          "$reduce": {
            "input": "$daily_user_sets",
            "initialValue": [],
            "in": { "$setUnion": ["$$value", "$$this"] }
          }
        }
      }
    }
  },
  {
    "$sort": { "week_end_sunday": 1, "companyId": 1 }
  }
]

